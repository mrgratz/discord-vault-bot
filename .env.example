# Discord Vault Bot Configuration
# Copy this file to .env and fill in the values.

# --- Required ---

# Bot token from https://discord.com/developers/applications → Bot → Token
DISCORD_BOT_TOKEN=your-bot-token-here

# Your Discord server (guild) ID. Enable Developer Mode in Discord settings,
# then right-click your server name → Copy Server ID.
DISCORD_GUILD_ID=123456789012345678

# Comma-separated Discord user IDs allowed to use the bot.
# Right-click your profile → Copy User ID (requires Developer Mode).
DISCORD_ALLOWED_USERS=123456789012345678

# --- Paths ---

# Where `claude -p` runs from. Should contain your CLAUDE.md / project config.
# Defaults to current working directory if not set.
CLAUDE_PROJECT_DIR=C:\path\to\your\claude\project

# Root of your Obsidian vault (used by /capture and /reel).
# Defaults to CLAUDE_PROJECT_DIR if not set.
# VAULT_PATH=C:\path\to\your\vault

# Where /capture saves notes. Defaults to VAULT_PATH/01_Inbox.
# INBOX_PATH=C:\path\to\your\vault\Inbox

# Where /session creates RAM files. Defaults to CLAUDE_PROJECT_DIR/Scratchpad.
# SCRATCHPAD_DIR=C:\path\to\your\project\Scratchpad

# --- Optional ---

# Claude model to use for chat. Default: sonnet (fast + cheap).
# Options: haiku, sonnet, opus
# CLAUDE_MODEL=sonnet

# Override the system prompt injected into Claude subprocess calls.
# SYSTEM_PROMPT=Be concise. Answer questions directly.

# Path to yt-dlp binary (for /reel command). Default: "yt-dlp" (assumes on PATH).
# YTDLP_PATH=C:\path\to\yt-dlp.exe

# Where /reel saves transcription notes. Defaults to VAULT_PATH/05_Reference/Instagram.
# REEL_OUTPUT_DIR=C:\path\to\your\vault\Reference\Instagram

# --- Voice (for /voice command) ---

# Groq API key for cloud speech-to-text (free tier at console.groq.com).
# Required for voice — there is no local fallback for STT.
# GROQ_API_KEY=gsk_your-key-here

# Path to FFmpeg binary. Default: "ffmpeg" (assumes on PATH).
# Install FFmpeg: https://ffmpeg.org/download.html
# FFMPEG_PATH=C:\path\to\ffmpeg.exe

# edge-tts voice for spoken responses. Default: en-US-JennyNeural.
# See: https://github.com/nicepkg/edge-tts for voice list.
# TTS_VOICE=en-US-JennyNeural

# TTS playback speed. Default: +25%.
# TTS_RATE=+25%

# Voice Activity Detection tuning (usually fine as defaults):
# VAD_SPEECH_THRESHOLD=0.5        # Silero VAD probability threshold for speech
# VAD_SILENCE_TIMEOUT=2.5         # Seconds of silence before processing utterance
# VAD_MIN_SPEECH_DURATION=0.5     # Ignore bursts shorter than this (seconds)
# VAD_SHORT_UTTERANCE_SECS=2.0    # Utterances shorter than this are held for merge
# VAD_HOLDBACK_WINDOW=3.0         # Seconds to wait for follow-on speech before dispatching
# NO_SPEECH_PROB_THRESHOLD=0.5    # Whisper no-speech probability rejection threshold
# MIN_VOLUME_DBFS=-30             # dBFS floor — reject audio quieter than this

# Session rotation — rotates the Claude session every N voice turns to prevent
# context bloat from slowing down responses. Discord channel history provides
# continuity across rotations.
# VOICE_ROTATION_TURNS=7
